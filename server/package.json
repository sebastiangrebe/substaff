{
  "name": "@substaff/server",
  "version": "0.2.7",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "SUBSTAFF_MIGRATION_PROMPT=never tsx watch --ignore ../ui/node_modules --ignore ../ui/.vite --ignore ../ui/dist src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@aws-sdk/client-s3": "^3.888.0",
    "@composio/core": "^0.6.4",
    "@qdrant/js-client-rest": "^1.17.0",
    "@substaff/adapter-blaxel-sandbox": "workspace:*",
    "@substaff/adapter-claude-local": "workspace:*",
    "@substaff/adapter-e2b-sandbox": "workspace:*",
    "@substaff/adapter-utils": "workspace:*",
    "@substaff/db": "workspace:*",
    "@substaff/shared": "workspace:*",
    "@types/archiver": "^7.0.0",
    "ai": "^6.0.116",
    "archiver": "^7.0.1",
    "better-auth": "1.4.18",
    "bullmq": "^5.70.4",
    "detect-port": "^2.1.0",
    "dotenv": "^17.0.1",
    "drizzle-orm": "^0.38.4",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "js-yaml": "^4.1.1",
    "multer": "^2.0.2",
    "open": "^11.0.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.1.3",
    "resend": "^6.9.3",
    "stripe": "^17.7.0",
    "ws": "^8.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "22",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}

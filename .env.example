# =============================================================================
# Substaff Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Core / Server
# -----------------------------------------------------------------------------

# PostgreSQL connection string (REQUIRED)
DATABASE_URL=postgres://substaff:substaff@localhost:5432/substaff

# Server host and port
HOST=0.0.0.0
PORT=3100

# External API URL for agents running in remote sandboxes (e.g. E2B).
# Agents use this to call back to the Substaff API. Set to a publicly
# reachable URL or tunnel (e.g. ngrok) when running agents in cloud sandboxes.
# SUBSTAFF_EXTERNAL_API_URL=https://c290-94-202-96-123.ngrok-free.app

# Serve the built UI from the server (set to true in production)
SERVE_UI=true

# Deployment mode — only "authenticated" is supported
# SUBSTAFF_DEPLOYMENT_MODE=authenticated

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# JWT secret for agent authentication (REQUIRED — auto-generated by `substaff onboard`)
# SUBSTAFF_AGENT_JWT_SECRET=

# BetterAuth secret (falls back to SUBSTAFF_AGENT_JWT_SECRET if not set)
BETTER_AUTH_SECRET=254dbb48c231b191895159eb8a3e0e799815533e82f4d4f24b01178fa251aa06

# Public URL for auth callbacks (auto-detected if not set)
# SUBSTAFF_AUTH_PUBLIC_BASE_URL=https://your-domain.com

# Agent JWT settings
# SUBSTAFF_AGENT_JWT_TTL_SECONDS=172800
# SUBSTAFF_AGENT_JWT_ISSUER=substaff
# SUBSTAFF_AGENT_JWT_AUDIENCE=substaff-api

# -----------------------------------------------------------------------------
# Object Storage (S3-compatible)
# -----------------------------------------------------------------------------

# S3 bucket for agent artifacts and file storage
SUBSTAFF_STORAGE_S3_BUCKET=substaff
SUBSTAFF_STORAGE_S3_REGION=us-east-1

# For local dev with MinIO (started via docker compose):
SUBSTAFF_STORAGE_S3_ENDPOINT=http://localhost:9000
SUBSTAFF_STORAGE_S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Optional key prefix for multi-tenant bucket sharing
# SUBSTAFF_STORAGE_S3_PREFIX=

# AWS credentials for production (or use IAM roles / instance profiles):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Redis (optional — enables real-time pub/sub, BullMQ job queues for billing/cost processing)
# -----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Vector Search — Qdrant + Voyage AI (optional — enables semantic knowledge search)
# -----------------------------------------------------------------------------

# Qdrant vector database
QDRANT_URL=https://0b6ed60b-1c84-4070-8e11-2e330319d80a.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhY2Nlc3MiOiJtIn0.YvueYM_DtCfqg7x-A8OQJQYGcBXRrAx0ubGj7nYkHko

# Voyage AI embeddings
VOYAGE_API_KEY=pa-pbWovwKID4yGPKLRMFlQcxo8u59APjFxkLsiltOBcOq
VOYAGE_INDEXING_MODEL=voyage-4-large
VOYAGE_RETRIEVAL_MODEL=voyage-4-lite

# -----------------------------------------------------------------------------
# Blaxel Sandboxed Execution (default — persistent cloud agent sandboxes)
# -----------------------------------------------------------------------------

BL_API_KEY=
BL_WORKSPACE=

# -----------------------------------------------------------------------------
# E2B Sandboxed Execution (alternative — ephemeral cloud agent sandboxes)
# -----------------------------------------------------------------------------

E2B_API_KEY=e2b_776757a4ab8ce8d65136187fe8a87c4d13967f29

# -----------------------------------------------------------------------------
# LLM Keys
# -----------------------------------------------------------------------------

# Managed keys — platform-provided keys billed to the vendor
MANAGED_ANTHROPIC_API_KEY=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
# MANAGED_OPENAI_API_KEY=

# Direct keys — used by agents when vendors don't provide their own
ANTHROPIC_API_KEY=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
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Composio Integrations (optional — enables 1000+ third-party tool integrations)
# -----------------------------------------------------------------------------

# Composio API key (from https://app.composio.dev/developers)
# COMPOSIO_API_KEY=

# -----------------------------------------------------------------------------
# Stripe Billing & Credits (optional — enables pay-as-you-go billing)
# -----------------------------------------------------------------------------

# Stripe API secret key (from https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (from Stripe Dashboard → Webhooks → Signing secret)
# Required to verify incoming webhook events (checkout.session.completed, subscription updates)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL of your app — used for Stripe Checkout success/cancel redirect URLs
# If not set, falls back to SUBSTAFF_API_URL or http://localhost:3100
# APP_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Email Alerts (optional — enables budget/balance notifications via Resend)
# -----------------------------------------------------------------------------

# Resend API key (from https://resend.com/api-keys)
# RESEND_API_KEY=re_...

# Sender address for alert emails (default: Substaff <noreply@substaff.com>)
# Must be a verified domain/email in your Resend account
# EMAIL_FROM=Substaff <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Heartbeat Scheduler
# -----------------------------------------------------------------------------

# Enable/disable the heartbeat scheduler (default: true)
# HEARTBEAT_SCHEDULER_ENABLED=true

# Heartbeat tick interval in milliseconds (default: 30000, minimum: 10000)
# HEARTBEAT_SCHEDULER_INTERVAL_MS=30000

# -----------------------------------------------------------------------------
# Migrations
# -----------------------------------------------------------------------------

# Auto-apply pending migrations on startup (default: prompt in TTY, auto in non-TTY)
# SUBSTAFF_MIGRATION_AUTO_APPLY=true

# Never prompt for migrations (skip them)
# SUBSTAFF_MIGRATION_PROMPT=never

# -----------------------------------------------------------------------------
# Secrets Management
# -----------------------------------------------------------------------------

# Secrets provider: "local-encrypted" (default) or "env"
# SUBSTAFF_SECRETS_PROVIDER=local-encrypted

# Master key for local encrypted secrets (auto-generated if not set)
# SUBSTAFF_SECRETS_MASTER_KEY=
# SUBSTAFF_SECRETS_MASTER_KEY_FILE=

# Strict mode — block agent execution if required secrets are missing
# SUBSTAFF_SECRETS_STRICT_MODE=false

# -----------------------------------------------------------------------------
# Sentry Error Monitoring (optional — enables error tracking and performance monitoring)
# -----------------------------------------------------------------------------

# Sentry DSN for server-side error tracking
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry environment tag (default: production)
# SENTRY_ENVIRONMENT=production

# Sentry traces sample rate (0.0 to 1.0, default: 0.1)
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry DSN for frontend (exposed to browser via Vite)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Frontend Sentry environment (default: production)
# VITE_SENTRY_ENVIRONMENT=production

# Frontend Sentry traces sample rate (default: 0.1)
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# PostHog Analytics (optional — enables frontend product analytics)
# -----------------------------------------------------------------------------

# PostHog project API key (from PostHog project settings)
# VITE_POSTHOG_KEY=phc_...

# PostHog instance host (default: https://us.i.posthog.com)
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------

# Maximum number of users allowed to sign up (no limit if unset)
# SUBSTAFF_MAX_SIGNUP_USERS=100

# Enable company deletion API (destructive — disabled by default)
# SUBSTAFF_ENABLE_COMPANY_DELETION=false

# Max upload size for attachments/assets in bytes (default: 10MB)
# SUBSTAFF_ATTACHMENT_MAX_BYTES=10485760

# Log directory override
# SUBSTAFF_LOG_DIR=

# Custom data directory (default: ~/.substaff)
# SUBSTAFF_HOME=

# Open browser on server start
# SUBSTAFF_OPEN_ON_LISTEN=false
